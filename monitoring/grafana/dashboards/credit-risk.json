{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current Model Version",
      "description": "Reads the credit_risk_model_info gauge labels. When this changes, downstream metric shifts can be attributed to a deploy.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "credit_risk_model_info",
          "legendFormat": "{{version}} ({{source}})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Predictions (last 1h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(credit_risk_prediction_class_total[1h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Approval Rate (LOW class share)",
      "description": "Share of predictions returning LOW risk (Approve decision). A sudden shift signals input distribution drift or threshold-effective miscalibration.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "sum(credit_risk_prediction_class_total{risk_label=\"LOW\"}) / sum(credit_risk_prediction_class_total)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.7}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Rate by Endpoint (RPS)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (handler, method) (rate(http_requests_total[1m]))",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"},
            "stacking": {"mode": "none", "group": "A"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "/predict Latency Percentiles",
      "description": "p50/p95/p99 latency for the /predict endpoint. SHAP latency overlay shows which fraction of total latency comes from explainability.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])))",
          "legendFormat": "p50 /predict",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])))",
          "legendFormat": "p95 /predict",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])))",
          "legendFormat": "p99 /predict",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(credit_risk_shap_computation_seconds_bucket[5m])))",
          "legendFormat": "p95 SHAP only",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.5}
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "p95 SHAP only"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}
            ]
          }
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Prediction Class Distribution",
      "description": "Rate of predictions issued, broken down by risk class. Stacked area shows total volume; ratio shifts indicate input drift or model recalibration.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 13},
      "targets": [
        {
          "expr": "sum by (risk_label) (rate(credit_risk_prediction_class_total[1m]))",
          "legendFormat": "{{risk_label}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 70,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "normal", "group": "A"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "LOW"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          },
          {
            "matcher": {"id": "byName", "options": "MEDIUM"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
          },
          {
            "matcher": {"id": "byName", "options": "HIGH"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": ["sum"]}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SHAP Computation Latency",
      "description": "p50/p95 of SHAP TreeExplainer compute time. SHAP is the dominant cost in /predict (LightGBM inference is microseconds; SHAP is ~6-10ms). Watch for upward drift here when adding features or rolling out larger models.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 13},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(credit_risk_shap_computation_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(credit_risk_shap_computation_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(credit_risk_shap_computation_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["credit-risk", "ml-ops", "production"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "Credit Risk API — Operations Dashboard",
  "uid": "credit-risk-ops",
  "version": 1,
  "weekStart": ""
}
